# Never bake secrets into the image
.env
.env.*

# Git & IDE
.git
.gitignore
.vscode
.idea

# Python cache
__pycache__
*.py[cod]
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache

# Local DB data / certs
db/data
certs/

